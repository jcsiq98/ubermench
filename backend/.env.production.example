# ─── Ubermench Backend — Production Environment ───────────────────
# These are the variables you need to set in Railway's dashboard.
# Required variables are marked with [REQUIRED].
# Optional ones work without being set (features degrade gracefully).

# ─── Server ───
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-frontend-domain.vercel.app    # [REQUIRED if using web dashboard]

# ─── Database / Redis (Railway provides these automatically) ───
DATABASE_URL=postgresql://user:password@host:5432/railway  # [REQUIRED] — Railway auto-fills this
REDIS_URL=redis://default:password@host:6379               # [REQUIRED] — Railway auto-fills this

# ─── Auth ───
JWT_SECRET=generate-a-64-char-random-string                # [REQUIRED]
JWT_REFRESH_SECRET=generate-another-64-char-random-string  # [REQUIRED]
OTP_EXPIRY_MINUTES=5

# ─── WhatsApp Cloud API (Meta) ───
WHATSAPP_TOKEN=your-permanent-whatsapp-token               # [REQUIRED]
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id              # [REQUIRED]
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token            # [REQUIRED]
WHATSAPP_API_URL=https://graph.facebook.com/v21.0

# ─── AI / LLM ───
OPENAI_API_KEY=sk-your-openai-key                          # [REQUIRED]
OPENAI_MODEL=gpt-4o

# ─── Optional services (app works without these) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
