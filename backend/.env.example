# ─── Ubermench Backend — Development Environment ──────────
# Copy this file to .env:  cp .env.example .env
# Then fill in the values marked with <...>

# ─── Database ───
# Option A: Embedded PostgreSQL (run `node scripts/start-db.js` from repo root)
DATABASE_URL="postgresql://handy:handy123@localhost:5433/handy_dev"
# Option B: Docker Compose (`docker-compose up -d` from repo root)
# DATABASE_URL="postgresql://ubermench:ubermench_dev@localhost:5432/ubermench_dev"

# ─── Redis (optional in dev — falls back to in-memory) ───
REDIS_URL=
# With Docker Compose: REDIS_URL=redis://localhost:6379

# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── Auth ───
JWT_SECRET=dev-jwt-secret-change-in-prod
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod
OTP_EXPIRY_MINUTES=5

# ─── WhatsApp Cloud API (Meta) ───
# Get from: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=<your-whatsapp-cloud-api-token>
WHATSAPP_PHONE_NUMBER_ID=<your-phone-number-id>
WHATSAPP_VERIFY_TOKEN=ubermench-2026-verify
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
# Without these, WhatsApp is disabled (webhook still receives, but can't send)

# ─── AI / LLM ───
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o
# Without OPENAI_API_KEY, AI returns a fallback message (no crash)

# ─── Cloudinary (optional — for identity verification photos) ───
# Get from: cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Without these, photo uploads return a dev placeholder URL (no crash)

# ─── Firebase (optional — for push notifications) ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Frontend URL (for verification links sent via WhatsApp) ───
FRONTEND_URL=http://localhost:3001
